  <diagram id="smart-contract-class-diagram" name="Smart Contract Class Diagram">
    <mxGraphModel dx="2020" dy="2110" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
