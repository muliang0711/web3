        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n!theme plain\nskinparam defaultFontName Arial\nskinparam ActivityBackgroundColor #ffffff\nskinparam ActivityBorderColor #000000\nskinparam ConditionEndStyle hline\nskinparam SwimlaneBorderColor #000000\n\ntitle Activity Diagram: Donation &amp; Reward Distribution\\n(Pet Treatment Campaign)\n\n|User|\nstart\n:Select active Pet Campaign &amp;\\nEnter Donation Amount;\n:Click \&quot;Donate\&quot;;\n\n|Pet Treatment dApp|\n:Wait for\\nauthentication;\n\n|Metamask|\n:Metamask authentication\\n(ETH Transfer);\n\nif (Transaction Status?) then (Transaction Cancel)\n    |User|\n    :Notify Payment\\nfailed / cancelled;\n    stop\nelse (Transaction Success)\n    |Pet Treatment dApp|\n    :Campaign.sol receives ETH\\n(Updates totalFunded);\n    :UserRegistry.sol records\\nDonation (Logs 1:1 CFR Points);\n    :Update Off-chain DB\\n(Supabase);\n    :Generate receipt;\n    \n    |User|\n    :Notify Donation\\nsuccessful and\\nshow receipt;\n    \n    partition \&quot;Reward Distribution Phase (CFR Token)\&quot; {\n        :Navigate to Profile;\n        :Click \&quot;Claim Tokens\&quot;;\n        \n        |Pet Treatment dApp|\n        :Wait for\\nauthentication;\n\n        |Metamask|\n        :Metamask authentication\\n(Contract Call);\n\n        if (Transaction Status?) then (Transaction Cancel)\n            |User|\n            :Notify Transaction\\nfailed / cancelled;\n            stop\n        else (Transaction Success)\n            |Pet Treatment dApp|\n            :RewardManager.sol verifies\\nPoints &amp; resets to 0;\n            :RewardToken.sol (CFR) mints\\nTokens to User Wallet;\n            :Update Off-chain DB\\n(Supabase);\n            \n            |User|\n            :Notify CFR Tokens\\nclaimed successfully;\n            stop\n        endif\n    }\nendif\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="d4WOsVZWoGXvF_kk4NiG-47">
