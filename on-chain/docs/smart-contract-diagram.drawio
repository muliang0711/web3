<mxfile host="app.diagrams.net" modified="2026-04-08T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="smart-contract-class-diagram" name="Smart Contract Class Diagram">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="factory" value="&lt;b&gt;CampaignFactory&lt;/b&gt;&lt;hr/&gt;+ campaigns: address[]&lt;br/&gt;+ userCampaigns: mapping(address =&amp;gt; address[])&lt;br/&gt;+ userRegistryAddress: address&lt;hr/&gt;+ createCampaign(...) : address&lt;br/&gt;+ getCampaigns() : address[]&lt;br/&gt;+ getUserCampaigns(address) : address[]&lt;br/&gt;+ getCampaignCount() : uint256" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="310" height="240" as="geometry" />
        </mxCell>
        <mxCell id="campaign" value="&lt;b&gt;Campaign&lt;/b&gt;&lt;hr/&gt;+ creator: address&lt;br/&gt;+ title: string&lt;br/&gt;+ description: string&lt;br/&gt;+ fundingTarget: uint256&lt;br/&gt;+ deadline: uint256&lt;br/&gt;+ totalFunded: uint256&lt;br/&gt;+ goalReached: bool&lt;br/&gt;+ fundsWithdrawn: bool&lt;br/&gt;+ isCancelled: bool&lt;br/&gt;+ contributions: mapping(address =&amp;gt; uint256)&lt;br/&gt;+ contributors: address[]&lt;br/&gt;+ userRegistry: IUserRegistry&lt;hr/&gt;+ contribute() : payable&lt;br/&gt;+ withdrawFunds()&lt;br/&gt;+ refund()&lt;br/&gt;+ refundAll()&lt;br/&gt;+ getCampaignInfo() : CampaignInfo&lt;br/&gt;+ getContribution(address) : uint256&lt;br/&gt;+ getContributors() : address[]&lt;br/&gt;+ getOutstandingRefundCount() : uint256" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="330" height="390" as="geometry" />
        </mxCell>
        <mxCell id="registry" value="&lt;b&gt;UserRegistry&lt;/b&gt;&lt;hr/&gt;+ users: mapping(address =&amp;gt; User)&lt;br/&gt;+ userDonations: mapping(address =&amp;gt; DonationRecord[])&lt;br/&gt;+ claimableRewards: mapping(address =&amp;gt; uint256)&lt;br/&gt;+ authorizedCampaigns: mapping(address =&amp;gt; bool)&lt;br/&gt;+ rewardManager: address&lt;br/&gt;+ campaignFactory: address&lt;br/&gt;+ owner: address&lt;hr/&gt;+ register(string)&lt;br/&gt;+ getUser(address) : User&lt;br/&gt;+ recordDonation(address,uint256)&lt;br/&gt;+ reverseDonation(address,uint256)&lt;br/&gt;+ getUserDonations(address) : DonationRecord[]&lt;br/&gt;+ getClaimableRewards(address) : uint256&lt;br/&gt;+ resetRewards(address)&lt;br/&gt;+ setRewardManager(address)&lt;br/&gt;+ setCampaignFactory(address)&lt;br/&gt;+ authorizeCampaign(address)" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="70" width="360" height="360" as="geometry" />
        </mxCell>
        <mxCell id="rewardManager" value="&lt;b&gt;RewardManager&lt;/b&gt;&lt;hr/&gt;+ rewardToken: IRewardToken&lt;br/&gt;+ userRegistry: IUserRegistry&lt;br/&gt;+ owner: address&lt;hr/&gt;+ claimRewards()&lt;br/&gt;+ revokeRewards(address,uint256)" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1010" y="150" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="token" value="&lt;b&gt;RewardToken&lt;/b&gt;&lt;hr/&gt;+ name(): string = CrowdfundReward&lt;br/&gt;+ symbol(): string = CFR&lt;hr/&gt;+ mint(address,uint256)&lt;br/&gt;+ distributeReward(address,uint256) : bool&lt;br/&gt;+ revokeReward(address,uint256) : bool" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1010" y="440" width="280" height="190" as="geometry" />
        </mxCell>
        <mxCell id="edge-factory-campaign" value="creates 1..*" style="endArrow=diamondThin;html=1;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;" edge="1" parent="1" source="factory" target="campaign">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-factory-registry" value="authorizes campaigns" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;dashed=1;strokeWidth=2;" edge="1" parent="1" source="factory" target="registry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-campaign-registry" value="uses" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;strokeWidth=2;" edge="1" parent="1" source="campaign" target="registry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-registry-rewardManager" value="calls revokeRewards()" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;dashed=1;strokeWidth=2;" edge="1" parent="1" source="registry" target="rewardManager">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-rewardManager-registry" value="reads / updates rewards" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;strokeWidth=2;" edge="1" parent="1" source="rewardManager" target="registry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-rewardManager-token" value="mints / burns CFR" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;strokeWidth=2;" edge="1" parent="1" source="rewardManager" target="token">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
