        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n!theme plain\nskinparam defaultFontName Arial\nskinparam ActivityBackgroundColor #ffffff\nskinparam ActivityBorderColor #000000\nskinparam ConditionEndStyle hline\nskinparam SwimlaneBorderColor #000000\n\ntitle Activity Diagram: Campaign Refund Process\\n(Pet Treatment Campaign)\n\n|User / Creator|\nstart\n:Navigate to Pet Campaign Page;\n:Click \&quot;Initiate Refund\&quot;;\n\n|Pet Treatment dApp|\nif (Deadline passed?) then (No)\n    :Display Error\\n(Campaign still active);\n    stop\nelse (Yes)\n    if (Funding Goal reached?) then (Yes)\n        :Display Error\\n(Goal met, funds locked\\nfor pet treatment);\n        stop\n    else (No)\n        :Wait for\\nauthentication;\n\n        |Metamask|\n        :Metamask authentication\\n(Smart Contract Call);\n\n        if (Transaction Status?) then (Transaction Cancel)\n            |User / Creator|\n            :Notify Transaction\\nfailed / cancelled;\n            stop\n        else (Transaction Success)\n            |Pet Treatment dApp|\n            \n            partition \&quot;Automatic On-Chain Refund &amp; Revocation\&quot; {\n                :Campaign.sol verifies eligibility\\nand unlocks ETH;\n                :Transfer ETH back to\\nContributor Wallet(s);\n                :UserRegistry.sol reverses\\nDonation Record;\n                :RewardManager.sol revokes\\nassociated CFR Tokens;\n            }\n            \n            :Update Off-chain DB\\n(Supabase) &amp; UI;\n            :Generate Refund receipt;\n            \n            |User / Creator|\n            :Notify Refund\\nsuccessful and\\nshow receipt;\n            stop\n        endif\n    endif\nendif\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="d4WOsVZWoGXvF_kk4NiG-46">
