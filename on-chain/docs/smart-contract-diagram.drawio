        <mxCell id="factory" parent="1" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" value="&lt;b&gt;CampaignFactory&lt;/b&gt;&lt;hr/&gt;+ campaigns: address[]&lt;br/&gt;+ userCampaigns: mapping(address =&amp;gt; address[])&lt;br/&gt;+ userRegistryAddress: address&lt;hr/&gt;+ createCampaign(...) : address&lt;br/&gt;+ getCampaigns() : address[]&lt;br/&gt;+ getUserCampaigns(address) : address[]&lt;br/&gt;+ getCampaignCount() : uint256" vertex="1">
          <mxGeometry height="240" width="310" x="60" y="70" as="geometry" />
        </mxCell>
        <mxCell id="campaign" parent="1" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" value="&lt;b&gt;Campaign&lt;/b&gt;&lt;hr/&gt;+ creator: address&lt;br/&gt;+ title: string&lt;br/&gt;+ description: string&lt;br/&gt;+ fundingTarget: uint256&lt;br/&gt;+ deadline: uint256&lt;br/&gt;+ totalFunded: uint256&lt;br/&gt;+ goalReached: bool&lt;br/&gt;+ fundsWithdrawn: bool&lt;br/&gt;+ isCancelled: bool&lt;br/&gt;+ contributions: mapping(address =&amp;gt; uint256)&lt;br/&gt;+ contributors: address[]&lt;br/&gt;+ userRegistry: IUserRegistry&lt;hr/&gt;+ contribute() : payable&lt;br/&gt;+ withdrawFunds()&lt;br/&gt;+ refund()&lt;br/&gt;+ refundAll()&lt;br/&gt;+ getCampaignInfo() : CampaignInfo&lt;br/&gt;+ getContribution(address) : uint256&lt;br/&gt;+ getContributors() : address[]&lt;br/&gt;+ getOutstandingRefundCount() : uint256" vertex="1">
          <mxGeometry height="390" width="330" x="60" y="380" as="geometry" />
        </mxCell>
        <mxCell id="registry" parent="1" style="shape=umlClass;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="&lt;b&gt;UserRegistry&lt;/b&gt;&lt;hr/&gt;+ users: mapping(address =&amp;gt; User)&lt;br/&gt;+ userDonations: mapping(address =&amp;gt; DonationRecord[])&lt;br/&gt;+ claimableRewards: mapping(address =&amp;gt; uint256)&lt;br/&gt;+ authorizedCampaigns: mapping(address =&amp;gt; bool)&lt;br/&gt;+ rewardManager: address&lt;br/&gt;+ campaignFactory: address&lt;br/&gt;+ owner: address&lt;hr/&gt;+ register(string)&lt;br/&gt;+ getUser(address) : User&lt;br/&gt;+ recordDonation(address,uint256)&lt;br/&gt;+ reverseDonation(address,uint256)&lt;br/&gt;+ getUserDonations(address) : DonationRecord[]&lt;br/&gt;+ getClaimableRewards(address) : uint256&lt;br/&gt;+ resetRewards(address)&lt;br/&gt;+ setRewardManager(address)&lt;br/&gt;+ setCampaignFactory(address)&lt;br/&gt;+ authorizeCampaign(address)" vertex="1">
          <mxGeometry height="360" width="360" x="520" y="70" as="geometry" />
        </mxCell>
