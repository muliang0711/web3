        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n!theme plain\nskinparam defaultFontName Arial\nskinparam ActivityBackgroundColor #ffffff\nskinparam ActivityBorderColor #000000\nskinparam ConditionEndStyle hline\nskinparam SwimlaneBorderColor #000000\n\ntitle Activity Diagram: User Registration\\n(Pet Treatment Campaign)\n\n|User|\nstart\n:Navigate to Registration Page;\n:Enter Display Name;\n:Click \&quot;Register profile\&quot;;\n\n|Pet Treatment dApp|\n:Validate input;\n:Wait for\\nauthentication;\n\n|Metamask|\n:Metamask authentication\\n(Smart Contract Call);\n\nif (Transaction Status?) then (Transaction Cancel)\n    |User|\n    :Notify Transaction\\nfailed / cancelled;\n    stop\nelse (Transaction Success)\n    |Pet Treatment dApp|\n    \n    partition \&quot;On-Chain Registration\&quot; {\n        :UserRegistry.sol creates\\nnew User record;\n        :Emit UserRegistered Event;\n    }\n    \n    partition \&quot;Off-Chain Profile Sync\&quot; {\n        :Save Wallet Address &amp; Name\\nto Off-chain DB (Supabase);\n    }\n    \n    |User|\n    :Notify Registration\\nsuccessful;\n    :Redirect to\\nCampaign Dashboard;\n    stop\nendif\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="d4WOsVZWoGXvF_kk4NiG-49">
