        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n!theme plain\nskinparam defaultFontName Arial\nskinparam ActivityBackgroundColor #ffffff\nskinparam ActivityBorderColor #000000\nskinparam ConditionEndStyle hline\nskinparam SwimlaneBorderColor #000000\n\ntitle Activity Diagram: Campaign Creation\\n(Pet Treatment Campaign)\n\n|User / Creator|\nstart\n:Navigate to \&quot;Create Campaign\&quot; page;\n:Enter Campaign Details\\n(Title, Target ETH, Duration, Image);\n:Click \&quot;Start Campaign\&quot;;\n\n|Pet Treatment dApp|\n:Wait for\\nauthentication;\n\n|Metamask|\n:Metamask authentication\\n(Smart Contract Call);\n\nif (Transaction Status?) then (Transaction Cancel)\n    |User / Creator|\n    :Notify Transaction\\nfailed / cancelled;\n    stop\nelse (Transaction Success)\n    |Pet Treatment dApp|\n    \n    partition \&quot;On-Chain Deployment &amp; Authorization\&quot; {\n        :CampaignFactory.sol deploys\\nnew Campaign.sol instance;\n        :CampaignFactory.sol calls\\nauthorizeCampaign() on UserRegistry;\n    }\n    \n    partition \&quot;Off-Chain Metadata Sync\&quot; {\n        :Upload Image to\\nStorage Bucket (app-media);\n        :Save Campaign Metadata to\\nOff-chain DB (Supabase);\n    }\n    \n    |User / Creator|\n    :Notify Campaign created\\nsuccessfully;\n    :Redirect to\\nCampaigns Dashboard;\n    stop\nendif\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="d4WOsVZWoGXvF_kk4NiG-48">
